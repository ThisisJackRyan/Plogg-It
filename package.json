{
  "name": "@plogg/web",
  "version": "0.0.0",
  "private": true,
  "description": "Plogg Club — map-based community trash reporting. Next.js web + Supabase.",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "clean": "rm -rf .next node_modules"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@clerk/nextjs": "^6.9.6",
    "@hookform/resolvers": "^3.10.0",
    "@plogg/core": "*",
    "@plogg/supabase": "*",
    "@plogg/types": "*",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.62.11",
    "@types/canvas-confetti": "^1.9.0",
    "ai": "^6.0.168",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "mapbox-gl": "^3.9.1",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-map-gl": "^7.1.7",
    "sonner": "^2.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@clerk/testing": "^2.0.17",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@plogg/config": "*",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
